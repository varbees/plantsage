ANTHROPIC_API_KEY=sk-ant-...
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
# For Vercel/serverless, prefer this instead of a file path:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Defaults are current as of May 2026 and can be overridden.
VERTEX_LOCATION=us-central1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_WEB_SEARCH_TOOL=web_search_20250305
PLANTSAGE_MAX_SEARCHES=12
PLANTSAGE_REPORTS_DIR=generated_reports
PLANTSAGE_UPLOADS_DIR=data/uploads
PLANTSAGE_DB_PATH=plantsage_observations.db
# On Vercel these default to /tmp/plantsage/... if omitted.

# Local smoke testing without external API calls:
# PLANTSAGE_MOCK_IDENTIFY=1
# PLANTSAGE_MOCK_RESEARCH=1
