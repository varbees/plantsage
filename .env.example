GEMINI_API_KEY=AIza...

# Defaults are current as of May 2026 and can be overridden.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RESEARCH_MODEL=gemini-2.5-flash
PLANTSAGE_RESEARCH_PROVIDER=gemini
PLANTSAGE_ASYNC_RESEARCH=0
# Optional fallback only:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
PLANTSAGE_MAX_SEARCHES=12
PLANTSAGE_REPORTS_DIR=generated_reports
PLANTSAGE_UPLOADS_DIR=data/uploads
PLANTSAGE_DB_PATH=plantsage_observations.db
# On Vercel these default to /tmp/plantsage/... if omitted.

# Local Postgres container. The app still uses SQLite until the Postgres adapter
# is wired in, but these values are ready for the next persistence phase.
PLANTSAGE_POSTGRES_HOST=127.0.0.1
PLANTSAGE_POSTGRES_PORT=55438
PLANTSAGE_POSTGRES_DB=plantsage
PLANTSAGE_POSTGRES_USER=plantsage
PLANTSAGE_POSTGRES_PASSWORD=plantsage_dev
DATABASE_URL=postgresql://plantsage:plantsage_dev@127.0.0.1:55438/plantsage

# Local smoke testing without external API calls:
# PLANTSAGE_MOCK_IDENTIFY=1
# PLANTSAGE_MOCK_RESEARCH=1
